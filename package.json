{
  "name": "llm-json-repair",
  "version": "0.1.3",
  "description": "Repair and parse broken JSON from LLM output (OpenAI, Claude, …) — fixes code fences, trailing commas, and truncated streams, then validates against your schema. Type-safe, zero-dependency, Standard Schema compatible",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "json",
    "repair",
    "json-repair",
    "parse",
    "json-parser",
    "llm",
    "llm-json",
    "ai",
    "openai",
    "anthropic",
    "claude",
    "gpt",
    "structured-output",
    "tool-calling",
    "truncated-json",
    "partial-json",
    "validation",
    "zod",
    "standard-schema",
    "json5",
    "fix",
    "typescript"
  ],
  "author": "Evgenii Pokalyuk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eugenepokalyuk/llm-json-repair.git"
  },
  "bugs": {
    "url": "https://github.com/eugenepokalyuk/llm-json-repair/issues"
  },
  "homepage": "https://github.com/eugenepokalyuk/llm-json-repair#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  }
}
